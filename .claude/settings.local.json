{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(git tag*)",
      "Bash(git restore*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git remote*)",
      "Bash(git init*)",
      "Bash(git config*)",
      "Bash(git mv*)",
      "Bash(git rm*)",
      "Bash(git ls-files*)",
      "Bash(git blame*)",
      "Bash(git reflog*)",
      "Bash(git cherry-pick*)",
      "Bash(git describe*)",
      "Bash(git rev-parse*)",
      "Bash(git worktree*)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(echo*)",
      "Bash(which*)",
      "Bash(where*)",
      "Bash(type*)",
      "Bash(file*)",
      "Bash(stat*)",
      "Bash(wc*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(diff*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(tree*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm -v)",
      "Bash(npm list*)",
      "Bash(npm ls*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npm view*)",
      "Bash(npm outdated*)",
      "Bash(npx --version)",
      "Bash(yarn --version)",
      "Bash(pnpm --version)",
      "Bash(gh auth status*)",
      "Bash(gh repo view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(docker compose*)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "PowerShell(Get-ChildItem*)",
      "PowerShell(Get-Content*)",
      "PowerShell(Get-Location)",
      "PowerShell(Get-Item*)",
      "PowerShell(Test-Path*)",
      "PowerShell(Select-String*)",
      "PowerShell(Measure-Object*)",
      "PowerShell(Get-NetTCPConnection -LocalPort 5173 -ErrorAction SilentlyContinue)",
      "PowerShell(Get-NetTCPConnection -LocalPort 8080 -ErrorAction SilentlyContinue)",
      "PowerShell(Get-NetTCPConnection -LocalPort 5432 -ErrorAction SilentlyContinue)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git branch --delete --force*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fx*)",
      "Bash(git clean -fdx*)",
      "Bash(git checkout -- *)",
      "Bash(git restore --source*)",
      "Bash(git rebase -i*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)",
      "Bash(git tag -d*)",
      "Bash(git push --delete*)",
      "Bash(git push origin --delete*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm -r*)",
      "Bash(rm -f*)",
      "PowerShell(Remove-Item*-Recurse*)",
      "PowerShell(rm -rf*)",
      "Bash(sudo*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(shutdown*)",
      "Bash(reboot*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$json = $input | ConvertFrom-Json; $cmd = $json.tool_input.command; if ($cmd -match 'docker\\s+compose\\s+up') { $conn = Get-NetTCPConnection -LocalPort 5432 -State Listen -ErrorAction SilentlyContinue; if ($conn) { Stop-Process -Id $conn.OwningProcess -Force -ErrorAction SilentlyContinue; Start-Sleep -Milliseconds 500 } }; if ($cmd -match 'gradlew.*bootRun') { $conn = Get-NetTCPConnection -LocalPort 8080 -State Listen -ErrorAction SilentlyContinue; if ($conn) { Stop-Process -Id $conn.OwningProcess -Force -ErrorAction SilentlyContinue; Start-Sleep -Milliseconds 500 } }; if ($cmd -match 'npm\\s+run\\s+dev') { $conn = Get-NetTCPConnection -LocalPort 5173 -State Listen -ErrorAction SilentlyContinue; if ($conn) { Stop-Process -Id $conn.OwningProcess -Force -ErrorAction SilentlyContinue; Start-Sleep -Milliseconds 500 } }",
            "shell": "powershell",
            "statusMessage": "ポート競合を確認しています..."
          }
        ]
      }
    ]
  }
}
